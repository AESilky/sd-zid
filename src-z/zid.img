;-0dd    ; Debugging output messages
-v      ; Verbose progress
sbc/sbc1.bin:0:7FFF              ; SBC image is at 0
dbm/dbmon.bin:1C000:1FFFF       ; Put the dbmon binary in region 7 of the ROM
