{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Make All",
            "type": "shell",
            "command": "make all",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${fileDirname}"
            }
        },
        {
            "label": "Make Clean",
            "type": "shell",
            "command": "make clean",
            "group": {
                "kind": "build"
            },
            "options": {
                "cwd": "${fileDirname}"
            }
        },
        {
            "label": "CUPL (current file)",
            "type": "shell",
            "command": "cupl.exe -m1nlxj ${fileBasenameNoExtension}.pld",
            "group": "build",
            "options": {
                "cwd": "${fileDirname}"
            }
        }
    ]
}